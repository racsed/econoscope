                          "fontSize": 15,
                          "fontWeight": "600"
                        }
                      ]
                    },
                    {
                      "type": "text",
                      "id": "3TYKn",
                      "fill": "$fg-secondary",
                      "textGrowth": "fixed-width",
                      "width": "fill_container",
                      "content": "Les courbes d'offre et de demande se croisent au point d'equilibre. A ce prix (45€), la quantite que les consommateurs souhaitent acheter correspond exactement a la quantite que les producteurs souhaitent vendre (80 unites). Au-dessus de ce prix, l'offre excede la demande ; en dessous, c'est l'inverse.",
                      "lineHeight": 1.6,
                      "fontFamily": "Inter",
                      "fontSize": 14,
                      "fontWeight": "normal"
                    }
                  ]
                }
              ]
            },
            {
              "type": "frame",
